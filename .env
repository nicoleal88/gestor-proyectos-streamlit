# Environment variables for Gestor de Proyectos Backups
# Copy this file to .env and fill in the values

# Database path (relative to project root or absolute)
DATABASE_PATH=data/gestor.db

# Backup directory (relative to project root)
BACKUP_DIR=backups

# Remote backup servers (space-separated list of "user@host:/path/to/backups/")
# Example: BACKUP_REMOTE_SERVERS="user@backup1.example.com:/backups/gestor/ user@backup2.example.com:/backups/gestor/"
BACKUP_REMOTE_SERVERS=

# SSH private key for remote backups (default: ~/.ssh/id_ed25519)
BACKUP_SSH_KEY=/home/nleal/.ssh/id_ed25519

# Number of days to retain backups (default: 7)
BACKUP_RETENTION_DAYS=7